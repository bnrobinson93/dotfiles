theme = TokyoNight Storm
background-blur-radius = 20

font-family = "Dank Mono Nerd Font Propo"
font-style = Regular
font-size = 16

gtk-single-instance = true
window-padding-x = 0
window-padding-y = 2
window-padding-balance = true
gtk-toolbar-style = flat
gtk-single-instance = true

# Cursor styling
cursor-style = "block"
cursor-style-blink = false

# Cursor styling + SSH session terminfo
# (all shell integration options must be passed together)
shell-integration-features = no-cursor,ssh-env

window-save-state = always

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Keyboard bindings - mirror tmux
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard

keybind = alt+arrow_down=resize_split:down,100
keybind = alt+arrow_up=resize_split:up,101
keybind = alt+arrow_left=resize_split:left,100
keybind = alt+arrow_right=resize_split:right,100

keybind = ctrl+n=new_window
keybind = ctrl+a>x=close_surface

keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:bottom
keybind = ctrl+a>k=goto_split:top
keybind = ctrl+a>l=goto_split:right

keybind = ctrl+a>shift+\=new_split:right
keybind = ctrl+a>-=new_split:down
keybind = ctrl+a>z=toggle_split_zoom

keybind = ctrl+a>n=next_tab
keybind = ctrl+a>p=previous_tab

keybind = ctrl+a>ctrl+r=reload_config
