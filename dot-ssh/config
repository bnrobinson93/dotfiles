Include /Users/brad.robinson/.colima/ssh_config

## Managed by dotfiles (stow). Safe to edit.
#
# Connection strategy per machine. Commit signing is separate — git/jj invoke
# ssh-keygen (or an override program) directly and never read this file.

# macOS: 1Password agent only. No IdentityFile listed, so nothing but the
# agent is ever offered.
Match exec "test $(uname) = Darwin"
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# Elsewhere with on-disk keys: use the key files, no agent (no prompts).
# Note: ssh_config quoting has no escapes — never nest \" inside the exec
# string (it splits the token and kills the whole config).
Match exec "test $(uname) != Darwin && test -f $HOME/.ssh/id_ed25519_GitHub"
  IdentityFile ~/.ssh/id_ed25519_GitHub
  IdentityFile ~/.ssh/id_ed25519_GitHubSigning
  IdentityAgent none

# Elsewhere without keys: fall back to the 1Password agent.
Match exec "test $(uname) != Darwin"
  IdentityAgent ~/.1password/agent.sock

