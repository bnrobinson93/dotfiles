#!/bin/bash
SEARCH_PATHS=()
while IFS= read -r line; do
  SEARCH_PATHS+=("$line")
done < <(sed -e '/^[[:space:]]*#/d' -e '/^[[:space:]]*$/d' -e "s|^~|$HOME|" "${XDG_CONFIG_HOME:-$HOME/.config}/search-paths.txt")
SEARCH_PATHS+=("$HOME/.dotfiles")

if type fd >/dev/null 2>&1; then
  selected_folder=$(fd --full-path "${SEARCH_PATHS[@]}" --min-depth 1 --max-depth 1 --type d | fzf)
else
  selected_folder=$(find "${SEARCH_PATHS[@]}" -mindepth 1 -maxdepth 1 -type d | fzf)
fi

if [[ -n $selected_folder ]]; then
  code -r "$selected_folder"
fi
