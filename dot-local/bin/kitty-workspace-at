#!/usr/bin/env bash
# kitty-workspace-at PATH — focus or create a kitty session (workspace) at PATH.
# Port of herdr-workspace-at. goto_session handles focus-if-live-else-create by name.

set -euo pipefail

if [[ $# -ne 1 ]]; then
  printf "Usage: kitty-workspace-at PATH\n" >&2
  exit 2
fi

file=$(kitty-session-gen "$1")
kitten @ action goto_session "$file"
