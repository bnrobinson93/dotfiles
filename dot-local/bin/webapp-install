#!/bin/bash -x

set -e

ICON_DIR="$HOME/.local/share/applications/icons"

if (($# < 2)); then
  echo "Usage: webapp-install <name> <url> [icon] [exec] [mime-types]"
  echo "  icon: URL, system icon name, or local path (optional — tries system icon then favicon)"
  exit 1
fi

APP_NAME="$1"
APP_URL="$2"
if [[ ! $APP_URL =~ ^[a-zA-Z][a-zA-Z0-9+.-]*: ]]; then
  APP_URL="https://$APP_URL"
fi
ICON_REF="$3"
CUSTOM_EXEC="$4" # Optional custom exec command
MIME_TYPES="$5"  # Optional mime types

# Ensure valid execution
if [[ -z $APP_NAME || -z $APP_URL ]]; then
  echo "You must set app name and app URL!"
  exit 1
fi

# Check for duplicates by Name= field across all local desktop files
EXISTING=$(
  grep --include="*.desktop" -ril "^Name=$APP_NAME$" \
    ~/.local/share/applications/ \
    /usr/share/applications/ \
    /var/lib/snapd/desktop/applications/ \
    2>/dev/null || true
  grep --include="*.desktop" -ril --dereference-recursive "^Name=$APP_NAME$" \
    ~/.local/share/flatpak/exports/share/applications/ \
    /var/lib/flatpak/exports/share/applications/ \
    2>/dev/null || true
)
if [[ -n $EXISTING ]]; then
  echo "An app named '$APP_NAME' already exists:"
  for f in $EXISTING; do
    echo "  $f"
  done
  read -r -p "Install anyway? [y/N] " REPLY
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Aborted."
    exit 0
  fi
  for f in $EXISTING; do
    if [[ $f == ~/.local/share/applications/* ]]; then
      rm -f "$f"
    fi
  done
fi

# Resolve icon: explicit arg > system icon > favicon fetch
mkdir -p "$ICON_DIR"

if [[ -n $ICON_REF ]]; then
  # Explicit icon provided: URL or system icon name or local path
  if [[ $ICON_REF =~ ^https?:// ]]; then
    ICON_PATH="$ICON_DIR/$APP_NAME.png"
    if ! curl -fsSL -o "$ICON_PATH" "$ICON_REF" || [[ ! -s $ICON_PATH ]]; then
      echo "Error: Failed to download icon."
      exit 1
    fi
  elif [[ -f $ICON_REF ]]; then
    ICON_PATH="$ICON_REF"
  else
    # Treat as system icon name (e.g. "firefox", "spotify")
    ICON_PATH="$ICON_REF"
  fi
else
  # Try system icon by lowercased app name first
  SYSTEM_ICON_NAME="${APP_NAME,,}"
  SYSTEM_ICON_NAME="${SYSTEM_ICON_NAME// /-}"
  if gtk-update-icon-cache --help &>/dev/null &&
    find /usr/share/icons ~/.local/share/icons -name "${SYSTEM_ICON_NAME}.*" 2>/dev/null | grep -q .; then
    ICON_PATH="$SYSTEM_ICON_NAME"
  else
    # Fall back to favicon
    FAVICON_URL="https://www.google.com/s2/favicons?domain=${APP_URL}&sz=128"
    ICON_PATH="$ICON_DIR/$APP_NAME.png"
    if ! curl -fsSL -o "$ICON_PATH" "$FAVICON_URL" || [[ ! -s $ICON_PATH ]]; then
      echo "Warning: Could not fetch favicon, no icon will be set."
      ICON_PATH=""
    fi
  fi
fi

# Use custom exec if provided, otherwise default behavior
EXEC_COMMAND="${CUSTOM_EXEC:-launch-webapp $APP_URL}"

DESKTOP_FILE="$HOME/.local/share/applications/$APP_NAME.desktop"

cat >"$DESKTOP_FILE" <<EOF
[Desktop Entry]
Version=1.0
Name=$APP_NAME
Comment=$APP_NAME
Exec=$EXEC_COMMAND
Terminal=false
Type=Application
Icon=$ICON_PATH
StartupNotify=true
EOF

# Add mime types if provided
if [[ -n $MIME_TYPES ]]; then
  echo "MimeType=$MIME_TYPES" >>"$DESKTOP_FILE"
fi

chmod +x "$DESKTOP_FILE"
update-desktop-database ~/.local/share/applications/ 2>/dev/null || true
echo "Installed: $APP_NAME"
