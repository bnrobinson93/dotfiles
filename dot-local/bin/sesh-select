#!/usr/bin/env bash
# sesh-select [all] — fzf picker for sesh sessions

list="sesh list --icons"

# Shared roots (see ~/.config/search-paths.txt) — surfaces folders zoxide hasn't seen yet.
SEARCH_PATHS=()
while IFS= read -r line; do
  SEARCH_PATHS+=("$line")
done < <(sed -e '/^[[:space:]]*#/d' -e '/^[[:space:]]*$/d' -e "s|^~|$HOME|" "${XDG_CONFIG_HOME:-$HOME/.config}/search-paths.txt")
folder_cmd="{ printf '%s\n' ~/.dotfiles; fd . ${SEARCH_PATHS[*]} -d 1 -t d -E .Trash; } | sed 's:/*$::' | awk 'NF && !seen[\$0]++'"

if [[ "$1" == "all" ]]; then
  listcmd=$($list -b)
  label=' all sessions '
else
  listcmd=$($list)
  label=' sesh '
fi

extra_opts=(
  --bind "tab:down,btab:up"
  --bind "ctrl-a:change-prompt(⚡️  )+reload($list -b)"
  --bind "ctrl-t:change-prompt(🪟  )+reload($list -t)"
  --bind "ctrl-f:change-prompt(📁  )+reload($folder_cmd)"
  --bind "ctrl-d:execute(tmux kill-session -t {2..})+change-prompt(⚡️  )+reload($list)"
  --preview-window "right:55%"
  --preview "sesh preview {}"
)

session=$(printf "%s\n" "$listcmd" |
  fzf --tmux center,80%,70% --no-sort --ansi \
    --border rounded --border-label "$label" \
    --header '  ^a all ^t tmux ^d tmux kill ^f find' \
    "${extra_opts[@]}")
[[ -n "$session" ]] && sesh connect "$session"
exit 0
