#!/usr/bin/env bash

SEARCH_PATHS=(
  ~
  ~/Documents
  ~/Downloads
  ~/Documents/code
  ~/Documents/code/tries
  ~/Documents/code/integrations-monorepo/integrations
  ~/Documents/code/js-lib-monorepo/libraries
)

show_all=0
selected_folder=""

while [[ $# -gt 0 ]]; do
  case "$1" in
  --all)
    show_all=1
    shift
    ;;
  *)
    selected_folder=$1
    shift
    ;;
  esac
done

filter_cmd=(cat)
if [[ $show_all -eq 0 ]]; then
  filter_cmd=(grep -Ev '(-ai|-ai[0-9]+|-exp|-explore)$')
fi

if [[ -z "$selected_folder" ]]; then
  if type fd >/dev/null 2>&1; then
    selected_folder=$(fd . "${SEARCH_PATHS[@]}" --min-depth 1 --max-depth 1 --type d | "${filter_cmd[@]}" | fzf)
  else
    selected_folder=$(find "${SEARCH_PATHS[@]}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | "${filter_cmd[@]}" | fzf)
  fi
fi

if [[ -z $selected_folder ]]; then
  exit 0
fi

selected_name=$(basename "$selected_folder" | tr . _)
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
  tmux new-session -s "$selected_name" -c "$selected_folder"
  exit 0
fi

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
  tmux new-session -ds "$selected_name" -c "$selected_folder"
fi

tmux switch-client -t "$selected_name"
