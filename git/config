[user]
	name = Brad R
  email = "31802085+bnrobinson93@users.noreply.github.com"
  # Per-machine override: ~/.gitlocal (see README, SSH section)
  signingkey = ~/.ssh/id_ed25519_GitHubSigning
[init]
  defaultBranch = main
[push]
	default = current
[pull]
  rebase = false
[alias]
  l = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --branches
  s = status --short
  c = commit -m
  ac = !git add -A && git commit --allow-empty -m
	acp = "!acp() { git commit -a -m \"$1\" && git push ; } ; acp"
[core]
  autocrlf = input
  excludesfile = ~/.gitignore
[commit]
	gpgsign = true
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = "~/.ssh/allowed_signers"
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[url "ssh://git@github.com/"]
  insteadOf = https://github.com/
[include]
    path = ~/.gitlocal
[includeIf "hasconfig:remote.*.url:**virtru**"]
    path = ~/.config/git/config_work
[includeIf "hasconfig:remote.*.url:**opentdf**"]
    path = ~/.config/git/config_work
